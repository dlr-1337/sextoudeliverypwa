# Sextou Delivery — contrato de ambiente local
# Copie para .env somente fora do controle de versão e preencha com valores reais.
# Todos os valores abaixo são placeholders seguros; nunca coloque segredos reais neste arquivo.

# Aplicação (ativo no M001)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_ENV="development"

# Banco de dados PostgreSQL (ativo no M001)
# Obrigatório para db:migrate, db:deploy, db:seed, smoke:m001 e verify:m001.
# Use um banco descartável/local; db:format e db:generate podem usar o placeholder de schema quando DATABASE_URL estiver ausente.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Autenticação e sessão (ativo no M001)
# AUTH_SECRET deve ser aleatório e ter pelo menos 32 caracteres no .env real.
# SESSION_COOKIE_NAME deve usar caracteres válidos para cookie HTTP.
# SESSION_MAX_AGE_DAYS deve ser um inteiro entre 1 e 365.
AUTH_SECRET="replace-with-a-long-random-secret"
SESSION_COOKIE_NAME="sextou_session"
SESSION_MAX_AGE_DAYS="30"

# Seed inicial do administrador (ativo no M001)
# db:seed exige estes valores, faz upsert de um ADMIN ativo e cria categorias base.
# Troque os placeholders no .env local; não use credenciais de produção.
SEED_ADMIN_NAME="Administrador Sextou"
SEED_ADMIN_EMAIL="admin@example.local"
SEED_ADMIN_PASSWORD="replace-with-a-strong-admin-password"

# Upload local em VPS/dev (ativo no M001)
# Somente UPLOAD_DRIVER="local" é suportado no M001.
# UPLOAD_DIR é runtime local e deve continuar ignorado pelo git.
# UPLOAD_PUBLIC_BASE_URL deve apontar para /uploads sem query/hash ou credenciais.
# UPLOAD_MAX_BYTES é inteiro positivo em bytes; imagens aceitas: PNG, JPEG/JPG e WebP.
UPLOAD_DRIVER="local"
UPLOAD_DIR="./uploads"
UPLOAD_PUBLIC_BASE_URL="http://localhost:3000/uploads"
UPLOAD_MAX_BYTES="5242880"

# Storage compatível com S3/R2/MinIO (placeholder para evolução futura)
# Ainda não é lido pelo runtime M001; mantenha valores fictícios até a integração real existir.
S3_ENDPOINT="https://s3-placeholder.example.local"
S3_REGION="us-east-1"
S3_BUCKET="sextou-delivery-placeholder"
S3_ACCESS_KEY_ID="replace-with-access-key-id"
S3_SECRET_ACCESS_KEY="replace-with-secret-access-key"
S3_FORCE_PATH_STYLE="true"

# Pagamentos fake/dev até definição do gateway real (placeholder futuro)
# Não coloque segredos reais de gateway neste grupo durante o M001.
FAKE_PAYMENT_PROVIDER="enabled"
FAKE_PAYMENT_WEBHOOK_SECRET="replace-with-fake-webhook-secret"
FAKE_PAYMENT_APPROVAL_MODE="manual"
