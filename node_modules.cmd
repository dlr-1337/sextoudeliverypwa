@echo off
setlocal EnableExtensions DisableDelayedExpansion

set "REQUEST=%~1"
if "%REQUEST%"=="" (
  echo Unsupported node_modules.cmd invocation. 1>&2
  exit /b 9009
)

set "RELATIVE_REQUEST=%REQUEST:/=\%"
if "%RELATIVE_REQUEST:~0,1%"=="\" set "RELATIVE_REQUEST=%RELATIVE_REQUEST:~1%"

set "TARGET=%~dp0node_modules\%RELATIVE_REQUEST%"
if not exist "%TARGET%" (
  echo Unsupported node_modules.cmd invocation: node_modules%REQUEST% 1>&2
  exit /b 9009
)

shift /1
set "FORWARDED_ARGS="

:collect_args
if "%~1"=="" goto run_target
set "FORWARDED_ARGS=%FORWARDED_ARGS% "%~1""
shift /1
goto collect_args

:run_target
call "%TARGET%" %FORWARDED_ARGS%
exit /b %ERRORLEVEL%
